# Variables del servicio Railway `api`.
# Copiar en Railway > servicio api > Variables.
# Reemplazar CORS_ALLOWED_ORIGINS cuando Railway genere el dominio publico del servicio spa.

SPRING_PROFILES_ACTIVE="docker,prod"
SERVER_PORT="8080"
PORT="8080"
SERVER_ADDRESS="::"

DB_URL="jdbc:postgresql://${{postgres.PGHOST}}:${{postgres.PGPORT}}/${{postgres.PGDATABASE}}"
DB_USER="${{postgres.PGUSER}}"
DB_PASS="${{postgres.PGPASSWORD}}"

CORS_ALLOWED_ORIGINS="https://spa-production-7348.up.railway.app"
PASSWORD_RESET_BASE_URL="https://spa-production-7348.up.railway.app"
PASSWORD_RESET_TTL_MINUTES="30"

# SMTP real para producción/preprod (no MailHog en Railway)
SMTP_HOST="smtp.tu-proveedor.com"
SMTP_PORT="587"
SMTP_USER="noreply@tu-dominio.com"
SMTP_PASS="REEMPLAZAR_SECRETO"
SMTP_AUTH="true"
SMTP_STARTTLS="true"

# Generar llaves nuevas para el entorno y pegar el PEM completo.
# Si Railway no importa bien multiline desde archivo, crear estas dos variables desde la UI.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
PEGA_AQUI_TU_LLAVE_PRIVADA_RSA
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
PEGA_AQUI_TU_LLAVE_PUBLICA_RSA
-----END PUBLIC KEY-----"
