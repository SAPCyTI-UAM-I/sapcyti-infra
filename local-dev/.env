# SAPCyTI — Local Development Environment Configuration
# Copy this file to .env in this directory before running docker compose

COMPOSE_PROJECT_NAME=sapcyti-local

# Host port for Nginx edge (default 80). 
# If port 80 is occupied, use e.g. 8888 and set SMOKE_BASE_URL=http://localhost:8888
EDGE_HTTP_PORT=80

# Database Configuration (Internal container network)
DB_URL=jdbc:postgresql://db:5432/sapcyti_dev
DB_USER=sapcyti
DB_PASS=sapcyti_dev_pass

# PostgreSQL Service configuration
POSTGRES_DB=sapcyti_dev
POSTGRES_USER=sapcyti
POSTGRES_PASSWORD=sapcyti_dev_pass

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost

# Smoke Test Credentials (Phase 6 will replace this with real Auth)
SMOKE_COORDINATOR_PASSWORD=changeme